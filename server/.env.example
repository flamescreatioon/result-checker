# Server runtime
PORT=5000

# Database connection
# Prefer DATABASE_URL_DIRECT on Vercel when available. If you only have the Neon pooler URL,
# the app will try to derive a direct host automatically.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:password@host/dbname?sslmode=require

# Admin authentication
# Use a bcrypt hash, not the plain password.
ADMIN_PASSWORD_HASH=$2b$10$replace_with_your_bcrypt_hash

# Allowed browser origins for CORS
FRONTEND_ORIGIN=https://your-frontend-project.vercel.app
# Optional comma-separated list if you have more than one frontend domain.
FRONTEND_ORIGINS=https://your-frontend-project.vercel.app,https://your-staging-project.vercel.app

# Optional database timeout tuning for serverless deployments
PG_CONNECTION_TIMEOUT_MS=15000
PG_QUERY_TIMEOUT_MS=30000PORT=5000
DATABASE_URL=postgresql://username:password@your-neon-host.neon.tech/dbname?sslmode=require
ADMIN_PASSWORD_HASH=
PG_CONNECTION_TIMEOUT_MS=15000
PG_QUERY_TIMEOUT_MS=30000
